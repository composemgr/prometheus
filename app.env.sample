# Prometheus — environment variable reference
# Copy relevant lines to a .env file alongside docker-compose.yaml
# Main configuration is in volumes/config/prometheus/prometheus.yml

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=${HOSTNAME}

# Time-series data retention period (e.g. 15d, 30d, 1y)
RETENTION_TIME=15d
